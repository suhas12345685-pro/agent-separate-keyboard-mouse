{
  "name": "@suhas12345685-pro/agent-separate-keyboard-mouse",
  "version": "1.0.0",
  "description": "Gives the AI agent its own isolated virtual keyboard and mouse via Win32 PostMessage — never steals the user's focus",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "extensions": ["src/index.ts"],
    "runtimeExtensions": ["dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.5.30"
    },
    "build": {
      "openclawVersion": "2026.6.2"
    },
    "install": {
      "clawhubSpec": "@suhas12345685-pro/agent-separate-keyboard-mouse",
      "minHostVersion": ">=2026.5.30"
    }
  }
}
